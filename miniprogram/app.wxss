page {
  --primary: #ff6b35;
  --primary-light: #fff0eb;
  --text: #333;
  --text2: #888;
  --border: #e8e8e8;
  --bg: #fafafa;
  --success: #27ae60;
  --radius: 12px;
  font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: var(--text);
  background: var(--bg);
  min-height: 100vh;
  font-size: 28rpx;
}

.page {
  padding: 48rpx 36rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 16rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: var(--text2);
  text-align: center;
  margin-bottom: 48rpx;
}

.btn {
  padding: 28rpx 48rpx;
  border-radius: var(--radius);
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  display: block;
}

.btn-primary { background: var(--primary); color: #fff; }
.btn-primary[disabled] { background: #ccc; }
.btn-outline { background: #fff; color: var(--primary); border: 2rpx solid var(--primary); }
.btn-large { width: 100%; padding: 32rpx; font-size: 34rpx; }

.input {
  width: 100%;
  padding: 28rpx 32rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  font-size: 30rpx;
  box-sizing: border-box;
  background: #fff;
}

.back-bar { margin-bottom: 32rpx; }
.back-btn { font-size: 28rpx; color: var(--text2); padding: 8rpx 0; }

.tags { display: flex; flex-wrap: wrap; gap: 20rpx; }
.tag {
  padding: 20rpx 36rpx; border: 2rpx solid var(--border);
  border-radius: 44rpx; background: #fff; font-size: 28rpx; color: var(--text);
}
.tag.selected {
  border-color: var(--primary); background: var(--primary-light);
  color: var(--primary); font-weight: 600;
}

.card {
  background: #fff; border: 1rpx solid var(--border);
  border-radius: var(--radius); padding: 32rpx; margin-bottom: 24rpx;
}
.card-name { font-size: 36rpx; font-weight: 700; }
.card-stats { display: flex; gap: 24rpx; font-size: 26rpx; color: var(--text2); margin-top: 12rpx; }
.stat-rating { color: var(--primary); font-weight: 700; }

.dish-tags { margin-top: 12rpx; }
.dish-label { font-size: 24rpx; color: var(--text2); }
.dish-tag {
  display: inline-block; padding: 6rpx 18rpx; background: var(--primary-light);
  color: var(--primary); border-radius: 24rpx; font-size: 24rpx; font-weight: 600;
  margin: 4rpx 8rpx 4rpx 0;
}

.photos { display: flex; gap: 12rpx; margin-bottom: 20rpx; white-space: nowrap; }
.photos image { width: 220rpx; height: 160rpx; border-radius: 8rpx; background: #f0f0f0; display: inline-block; }

.platforms { display: flex; gap: 16rpx; margin-top: 20rpx; }
.platform-link {
  flex: 1; text-align: center; padding: 20rpx 0; border-radius: 8rpx;
  font-size: 28rpx; font-weight: 700;
}
.platform-link.meituan { background: #FFD100; color: #333; }
.platform-link.eleme { background: #0085FF; color: #fff; }

.food-link {
  display: block; text-align: center; padding: 16rpx; color: #e8734a;
  font-size: 26rpx; font-weight: 600; margin-top: 12rpx;
}

.spinner { width: 60rpx; height: 60rpx; margin: 80rpx auto; border: 4rpx solid var(--border); border-top-color: var(--primary); border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

.suggestions {
  background: #fff; border: 1rpx solid var(--border); border-radius: var(--radius);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1); margin-top: 12rpx; max-height: 480rpx; overflow-y: auto;
}
.sug-item { padding: 28rpx; border-bottom: 1rpx solid var(--border); }
.sug-name { font-size: 30rpx; font-weight: 600; display: block; }
.sug-addr { font-size: 24rpx; color: var(--text2); margin-top: 6rpx; display: block; }

.history { margin-top: 40rpx; }
.history-title { font-size: 28rpx; color: var(--text2); font-weight: 600; margin-bottom: 16rpx; display: block; }
.history-chips { display: flex; flex-wrap: wrap; gap: 12rpx; }
.history-chip {
  display: inline-block; padding: 16rpx 28rpx; border: 1rpx solid var(--border);
  border-radius: 36rpx; background: #fff; font-size: 26rpx;
}

.error-box { text-align: center; padding: 100rpx 40rpx; }
.error-icon { font-size: 100rpx; display: block; margin-bottom: 24rpx; }
.error-text { font-size: 30rpx; color: var(--text2); margin-bottom: 36rpx; }

.skeleton { background: #f0f0f0; border-radius: 8rpx; height: 36rpx; margin-bottom: 20rpx; }
.skeleton.short { width: 60%; }
.skeleton.medium { width: 80%; }

.dietary-count { text-align: center; margin-top: 28rpx; font-size: 26rpx; color: var(--text2); }

.wheel-container { display: flex; flex-direction: column; align-items: center; margin-top: 40rpx; }
.wheel-wrap { position: relative; width: 500rpx; height: 500rpx; }
.wheel-arrow {
  position: absolute; top: -20rpx; left: 50%; transform: translateX(-50%);
  width: 0; height: 0; border-left: 24rpx solid transparent; border-right: 24rpx solid transparent;
  border-top: 48rpx solid var(--primary); z-index: 10;
}
.wheel-canvas { width: 500rpx; height: 500rpx; }
.wheel-center {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
  width: 100rpx; height: 100rpx; border-radius: 50%; background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15); display: flex; align-items: center;
  justify-content: center; font-weight: 700; font-size: 28rpx; color: var(--primary);
}

.category-badge {
  display: inline-block; padding: 32rpx 80rpx; border-radius: 48rpx;
  background: var(--primary-light); color: var(--primary); font-size: 56rpx; font-weight: 700;
}

.custom-row { display: flex; gap: 16rpx; align-items: center; }
.custom-input { width: 260rpx; padding: 18rpx 24rpx; border: 2rpx solid var(--primary); border-radius: 44rpx; font-size: 28rpx; }

<view class="page">
  <view class="back-bar"><text class="back-btn" bindtap="goBack">← 换一类</text></view>
  <text class="page-title">{{category}} · {{locName}}</text>
  <text class="page-subtitle">{{loading ? '搜索中...' : '找到 ' + results.length + ' 家好店'}}</text>

  <!-- loading -->
  <view wx:if="{{loading}}">
    <view class="card" wx:for="{{[1,2,3]}}" wx:key="*this">
      <view class="skeleton short"></view>
      <view class="skeleton medium"></view>
      <view class="skeleton" style="height:50rpx;"></view>
    </view>
  </view>

  <!-- error -->
  <view wx:elif="{{error}}" class="error-box">
    <text class="error-icon">😵</text>
    <text class="error-text">{{error}}</text>
    <view class="btn btn-primary" style="width:400rpx;margin:0 auto;" bindtap="onRetry">点击重试</view>
  </view>

  <!-- empty -->
  <view wx:elif="{{results.length === 0}}" class="error-box">
    <text class="error-icon">🔍</text>
    <text class="error-text">附近没找到符合条件的{{category}}</text>
    <view class="btn btn-primary" style="width:400rpx;margin:0 auto;" bindtap="goBack">换一类</view>
  </view>

  <!-- results -->
  <view wx:else style="flex:1;overflow-y:auto;">
    <view class="card" wx:for="{{results}}" wx:key="id">
      <!-- photos -->
      <view class="photos" wx:if="{{item.photos.length > 0}}">
        <image wx:for="{{item.photos}}" wx:key="*this" src="{{item}}" mode="aspectFill" lazy-load />
      </view>

      <text class="card-name">{{item.name}}</text>
      <view class="card-stats">
        <text class="stat-rating" wx:if="{{item.rating > 0}}">★ {{item.rating}}</text>
        <text wx:if="{{item.distance > 0}}">{{item.distance}}km</text>
      </view>

      <view class="dish-tags" wx:if="{{item.dishes.length > 0}}">
        <text class="dish-label">推荐菜：</text>
        <text class="dish-tag" wx:for="{{item.dishes}}" wx:key="*this">{{item}}</text>
      </view>

      <text wx:if="{{item.platforms[0].estimatedPrice > 0}}" style="font-size:26rpx;color:var(--text2);margin-top:12rpx;display:block;">
        人均 ¥{{item.platforms[0].estimatedPrice}}
      </text>

      <view class="food-link" data-name="{{item.name}}" bindtap="copyDianping">复制链接查看菜品照片</view>

      <view class="platforms">
        <view class="platform-link meituan" data-name="{{item.name}}" bindtap="copyMeituan">美团搜索</view>
        <view class="platform-link eleme" data-name="{{item.name}}" bindtap="copyEleme">饿了么搜索</view>
      </view>
    </view>
    <view style="height:40rpx;"></view>
  </view>
</view>

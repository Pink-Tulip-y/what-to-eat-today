<view class="page">
  <view class="back-bar"><text class="back-btn" bindtap="goBack">← 返回</text></view>
  <text class="page-title">命运转盘</text>
  <text class="page-subtitle">点击按钮，让命运决定吃什么</text>

  <view class="wbox">
    <view class="wpointer"></view>
    <view class="wdisc" style="background:{{gradient}};transform:rotate({{rotation}}deg);{{spinning ? 'transition:transform 3.5s cubic-bezier(0.17,0.67,0.12,0.99)' : ''}}">
      <view class="wseg-text" wx:for="{{labels}}" wx:key="idx" style="transform:rotate({{item.angle}}deg)">
        <text class="wlabel">{{item.name}}</text>
      </view>
    </view>
    <view class="wcenter">GO</view>
  </view>

  <view class="btn btn-primary btn-large" style="margin-top:60rpx;" bindtap="spin">
    {{spinning ? '转盘中...' : (hasSpun ? '再转一次' : '🎯 开始转动')}}
  </view>
</view>

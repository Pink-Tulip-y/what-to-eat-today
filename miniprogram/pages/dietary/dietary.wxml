<view class="page">
  <view class="back-bar"><text class="back-btn" bindtap="goBack">← 返回</text></view>
  <text class="page-title">有什么忌口吗？</text>
  <text class="page-subtitle">选好后自动避开不合口味的食物</text>

  <view class="tags">
    <view wx:for="{{options}}" wx:key="key" class="tag {{selected.indexOf(item.key) > -1 ? 'selected' : ''}}" data-key="{{item.key}}" bindtap="toggle">
      {{item.label}}
    </view>

    <view wx:for="{{customItems}}" wx:key="*this" class="tag selected" data-item="{{item}}" bindtap="removeCustom">
      {{item}} ✕
    </view>

    <view wx:if="{{showInput}}" class="custom-row">
      <input class="custom-input" placeholder="输入忌口..." value="{{customVal}}" bindinput="e => customVal = e.detail.value" bindconfirm="addCustom" focus />
      <view class="btn btn-primary" style="padding:18rpx 32rpx;font-size:26rpx;" bindtap="addCustom">添加</view>
    </view>

    <view wx:else class="tag" style="border-style:dashed;color:var(--text2);" bindtap="e => showInput = true">+ 其他</view>
  </view>

  <view style="margin-top:auto;">
    <view class="btn btn-primary btn-large" bindtap="goNext">下一步，转盘来决定！</view>
    <view class="dietary-count">已选 {{selected.length + customItems.length}} 项{{selected.length + customItems.length === 0 ? '，无特别忌口' : ''}}</view>
  </view>
</view>

/* pages/index/index.wxss */
.page {
  padding: 24px 16px;
  min-height: 100vh;
  background: #fafafa;
}

.page-title {
  display: block;
  font-size: 24px;
  font-weight: 700;
  text-align: center;
  margin-bottom: 8px;
  color: #333;
}

.page-subtitle {
  display: block;
  font-size: 14px;
  color: #888;
  text-align: center;
  margin-bottom: 24px;
}

/* 地点搜索 */
.search-row {
  display: flex;
  gap: 8px;
}

.location-input {
  flex: 1;
  padding: 14px 16px;
  border: 2px solid #e8e8e8;
  border-radius: 12px;
  font-size: 16px;
  background: #fff;
}

.gps-btn {
  padding: 14px 12px;
  font-size: 14px;
  background: #e8e8e8;
  border-radius: 12px;
  white-space: nowrap;
  line-height: 1;
  border: none;
}

.suggestions-list {
  background: #fff;
  border: 1px solid #e8e8e8;
  border-radius: 12px;
  margin-top: 4px;
  overflow: hidden;
}

.suggestion-item {
  padding: 12px 16px;
  border-bottom: 1px solid #f0f0f0;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.sug-name {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  display: block;
}

.sug-addr {
  font-size: 12px;
  color: #888;
}

.selected-hint {
  margin-top: 10px;
  font-size: 13px;
  color: #27ae60;
  font-weight: 600;
}

/* 按钮 */
.btn-primary {
  width: 100%;
  margin-top: 20px;
  padding: 16px;
  border-radius: 12px;
  background: #ff6b35;
  color: #fff;
  font-size: 18px;
  font-weight: 600;
  border: none;
}

.btn-outline {
  width: 100%;
  margin-top: 12px;
  padding: 14px;
  border-radius: 12px;
  background: #fff;
  color: #ff6b35;
  border: 2px solid #ff6b35;
  font-size: 16px;
}

/* 忌口 */
.back-bar { margin-bottom: 12px; }
.back-btn { font-size: 14px; color: #888; }

.diet-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 20px;
}

.diet-tag {
  padding: 10px 18px;
  border: 2px solid #e8e8e8;
  border-radius: 24px;
  font-size: 14px;
  background: #fff;
}

.diet-tag.selected {
  border-color: #ff6b35;
  background: #fff0eb;
  color: #ff6b35;
  font-weight: 600;
}

.diet-count {
  display: block;
  text-align: center;
  font-size: 13px;
  color: #888;
  margin-bottom: 20px;
}

/* 确认 */
.category-result {
  text-align: center;
  padding: 30px 0;
}

.category-badge {
  font-size: 36px;
  font-weight: 700;
  color: #ff6b35;
  display: block;
  margin-bottom: 8px;
}

.category-guess {
  font-size: 14px;
  color: #888;
}

/* 结果 */
.loading-text {
  text-align: center;
  padding: 40px 0;
  color: #888;
}

.error-box {
  text-align: center;
  padding: 32px 16px;
  color: #888;
}

.result-list {
  margin-bottom: 16px;
}

.result-card {
  background: #fff;
  border: 1px solid #e8e8e8;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 10px;
}

.result-name {
  font-size: 16px;
  font-weight: 700;
  color: #333;
}

.result-stats {
  display: flex;
  gap: 12px;
  margin: 6px 0;
  font-size: 13px;
  color: #888;
}

.stat-rating { color: #ff6b35; font-weight: 600; }
.stat-sales, .stat-dist { color: #aaa; }

.avg-price {
  font-size: 14px;
  color: #888;
}

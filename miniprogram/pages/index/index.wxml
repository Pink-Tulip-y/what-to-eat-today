<view class="page">
  <text class="page-title">今天吃什么？</text>
  <text class="page-subtitle">输入位置，帮你找到附近最好的外卖</text>

  <input class="input" placeholder="搜索地点，如：望京SOHO" value="{{query}}" bindinput="onInput" bindconfirm="goNext" />

  <view class="suggestions" wx:if="{{suggestions.length > 0}}">
    <view class="sug-item" wx:for="{{suggestions}}" wx:key="name" data-suggestion="{{item}}" bindtap="onSelect">
      <text class="sug-name">{{item.name}}</text>
      <text class="sug-addr">{{item.address}}</text>
    </view>
  </view>

  <text wx:if="{{selected}}" style="color:var(--success);font-size:26rpx;margin-top:20rpx;text-align:center;">
    已选：{{selected.name}}
  </text>

  <view style="margin-top:auto;padding-top:80rpx;">
    <view class="btn btn-primary btn-large {{query ? '' : 'disabled'}}" bindtap="goNext">下一步</view>
  </view>

  <view class="history" wx:if="{{history.length > 0}}">
    <text class="history-title">最近搜索</text>
    <view class="history-chips">
      <text class="history-chip" wx:for="{{history}}" wx:key="time" data-history="{{item}}" bindtap="replayHistory">
        {{item.category}}·{{item.location}}
      </text>
    </view>
  </view>
</view>
